{#
  Composant Skip Link - Lien d'évitement pour navigation clavier (Accessibilité WCAG AA)

  Usage:
    {{ include('components/skip_link.html.twig') }}

  À placer au début de <body>, avant tout autre contenu
#}
<a href="#main-content" class="visually-hidden" style="position: fixed; top: 0; left: 0; background: var(--primary); color: white; padding: 12px 20px; z-index: 9999; text-decoration: none; font-weight: 600;">
  Aller au contenu principal
</a>
