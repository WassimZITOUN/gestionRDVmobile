{#
  Composant Appointment Card - Carte de rendez-vous réutilisable

  Usage:
    {{ include('components/appointment_card.html.twig', {
      rdv: rendezVous,
      show_actions: true,
      user_role: 'patient'
    }) }}

  Params:
    - rdv: Objet RendezVous (requis)
    - show_actions: true|false - Afficher les boutons d'action (default: true)
    - user_role: 'patient'|'medecin'|'assistant' - Détermine quelle info afficher
#}
<article class="card appointment-card">
  <div class="flex-between flex-center">
    <div>
      <h3 style="margin: 0 0 8px 0; font-size: 1.1rem;">
        {{ rdv.debut|date('d/m/Y') }}
      </h3>
      <p class="text-meta" style="margin: 0;">
        {{ rdv.debut|date('H:i') }} - {{ rdv.fin|date('H:i') }}
      </p>
    </div>
    {% set badge_type = rdv.etat.libelle == 'confirmé' ? 'success' : (rdv.etat.libelle == 'annulé' ? 'danger' : (rdv.etat.libelle == 'refusé' ? 'danger' : 'primary')) %}
    {{ include('components/badge.html.twig', {
      type: badge_type,
      label: rdv.etat.libelle|capitalize
    }) }}
  </div>

  <div style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-light);">
    {% if user_role == 'patient' %}
      <p style="margin: 4px 0;"><strong>Médecin :</strong> Dr {{ rdv.medecin.nom }} {{ rdv.medecin.prenom }}</p>
    {% elseif user_role in ['medecin', 'assistant'] %}
      <p style="margin: 4px 0;"><strong>Patient :</strong> {{ rdv.patient.nom }} {{ rdv.patient.prenom }}</p>
      <p class="text-meta" style="margin: 4px 0;"><small>{{ rdv.patient.email }}</small></p>
    {% endif %}
  </div>

  {% if show_actions|default(true) %}
    <div class="flex-row" style="margin-top: 16px; padding-top: 16px; border-top: 1px solid var(--border-light);">
      {{ include('components/button.html.twig', {
        href: path('mes_rendez_vous_show', {id: rdv.id}),
        label: 'Détails',
        icon: '📋',
        variant: 'primary',
        size: 'sm'
      }) }}

      {% if rdv.etat.libelle == 'demandé' %}
        {{ include('components/button.html.twig', {
          href: path('mes_rendez_vous_edit', {id: rdv.id}),
          label: 'Modifier',
          icon: '✏️',
          variant: 'warning',
          size: 'sm'
        }) }}
      {% endif %}

      {% if user_role in ['medecin', 'assistant'] and rdv.etat.libelle == 'demandé' %}
        <form method="post" action="{{ path('mes_rendez_vous_confirm', {id: rdv.id}) }}" style="display: inline;">
          <button type="submit" class="btn btn-success btn-sm">✓ Confirmer</button>
        </form>
        <form method="post" action="{{ path('mes_rendez_vous_refuse', {id: rdv.id}) }}" style="display: inline;">
          <button type="submit" class="btn btn-danger btn-sm">✗ Refuser</button>
        </form>
      {% endif %}
    </div>
  {% endif %}
</article>
