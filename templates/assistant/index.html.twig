{% extends 'base.html.twig' %}

{% block title %}Gestion des assistants{% endblock %}

{% block body %}
<div class="container" style="max-width: 1100px; padding-top: 32px; padding-bottom: 48px;">
    {# Page Header #}
    <div class="page-header">
        <div class="page-header-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                <circle cx="9" cy="7" r="4"></circle>
                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
        </div>
        <div class="page-header-content">
            <h1>Gestion des assistants</h1>
            <p class="page-header-subtitle">Consultez et gérez les assistants médicaux</p>
        </div>
        <a href="{{ path('app_assistant_new') }}" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Nouvel assistant
        </a>
    </div>

    {# Liste des assistants #}
    {% if assistants is not empty %}
        <div class="assistants-grid">
            {% for assistant in assistants %}
                <div class="assistant-card">
                    <div class="assistant-avatar">
                        {{ assistant.prenom is defined and assistant.prenom ? assistant.prenom|slice(0,1)|upper : 'A' }}{{ assistant.nom is defined and assistant.nom ? assistant.nom|slice(0,1)|upper : '' }}
                    </div>
                    <div class="assistant-info">
                        <h3 class="assistant-name">
                            {% if assistant.prenom is defined and assistant.nom is defined %}
                                {{ assistant.prenom }} {{ assistant.nom }}
                            {% else %}
                                Assistant #{{ assistant.id }}
                            {% endif %}
                        </h3>
                        <p class="assistant-email">{{ assistant.email }}</p>
                        <div class="assistant-roles">
                            {% for role in assistant.roles %}
                                {% if role != 'ROLE_USER' %}
                                    <span class="role-tag">{{ role|replace({'ROLE_': ''})|lower|capitalize }}</span>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    <div class="assistant-actions">
                        <a href="{{ path('app_assistant_show', {'id': assistant.id}) }}" class="action-btn" title="Voir détails">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                <circle cx="12" cy="12" r="3"></circle>
                            </svg>
                        </a>
                        <a href="{{ path('app_assistant_edit', {'id': assistant.id}) }}" class="action-btn" title="Modifier">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                            </svg>
                        </a>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="empty-state">
            <div class="empty-state-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                    <circle cx="9" cy="7" r="4"></circle>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                </svg>
            </div>
            <h2>Aucun assistant enregistré</h2>
            <p>Vous n'avez pas encore ajouté d'assistant. Créez-en un pour commencer.</p>
            <a href="{{ path('app_assistant_new') }}" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Créer le premier assistant
            </a>
        </div>
    {% endif %}
</div>

<style>
/* ===== Page Header Premium ===== */
.page-header {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    margin-bottom: 40px;
    flex-wrap: wrap;
    animation: slideUp 0.4s ease-out;
}

@keyframes slideUp {
    from {
        opacity: 0;
        transform: translateY(16px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.page-header-icon {
    width: 64px;
    height: 64px;
    background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    flex-shrink: 0;
    box-shadow: 
        0 8px 24px -4px rgba(245, 158, 11, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.3);
    transform: rotate(-3deg);
}

.page-header-content {
    flex: 1;
    min-width: 200px;
}

.page-header-content h1 {
    margin: 0 0 6px;
    font-size: 1.875rem;
    font-weight: 800;
    background: linear-gradient(135deg, #1e293b 0%, #475569 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.page-header-subtitle {
    margin: 0;
    color: #64748b;
    font-size: 1.05rem;
}

/* ===== Button ===== */
.btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 24px;
    border-radius: 14px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    border: none;
    cursor: pointer;
    font-family: inherit;
    flex-shrink: 0;
}

.btn-primary {
    background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
    color: white;
    box-shadow: 
        0 6px 20px -4px rgba(245, 158, 11, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

.btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 
        0 12px 32px -4px rgba(245, 158, 11, 0.5),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
}

/* ===== Assistants Grid ===== */
.assistants-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 20px;
}

.assistant-card {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 24px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(255, 255, 255, 0.95) 100%);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.9);
    border-radius: 20px;
    box-shadow: 
        0 4px 20px -4px rgba(0, 0, 0, 0.08),
        inset 0 1px 0 rgba(255, 255, 255, 1);
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    animation: slideUp 0.5s ease-out both;
}

.assistant-card:nth-child(1) { animation-delay: 0.1s; }
.assistant-card:nth-child(2) { animation-delay: 0.15s; }
.assistant-card:nth-child(3) { animation-delay: 0.2s; }
.assistant-card:nth-child(4) { animation-delay: 0.25s; }

.assistant-card:hover {
    transform: translateY(-4px);
    box-shadow: 
        0 16px 40px -8px rgba(0, 0, 0, 0.12),
        0 4px 12px -4px rgba(245, 158, 11, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 1);
    border-color: rgba(245, 158, 11, 0.2);
}

.assistant-avatar {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #f59e0b 0%, #ea580c 100%);
    color: white;
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    font-weight: 700;
    flex-shrink: 0;
    box-shadow: 
        0 4px 12px rgba(245, 158, 11, 0.3),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
    transition: transform 0.3s ease;
}

.assistant-card:hover .assistant-avatar {
    transform: scale(1.05) rotate(-3deg);
}

.assistant-info {
    flex: 1;
    min-width: 0;
}

.assistant-name {
    margin: 0 0 4px;
    font-size: 1.15rem;
    font-weight: 700;
    color: #1e293b;
}

.assistant-email {
    margin: 0 0 10px;
    font-size: 0.9rem;
    color: #64748b;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.assistant-roles {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
}

.role-tag {
    font-size: 0.75rem;
    font-weight: 600;
    color: #d97706;
    background: rgba(245, 158, 11, 0.12);
    padding: 4px 10px;
    border-radius: 50px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

.assistant-actions {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
}

.action-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: white;
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    color: #64748b;
    text-decoration: none;
    transition: all 0.2s ease;
}

.action-btn:hover {
    color: #f59e0b;
    border-color: #f59e0b;
    background: rgba(245, 158, 11, 0.05);
    transform: scale(1.08);
}

/* ===== Empty State ===== */
.empty-state {
    text-align: center;
    padding: 72px 40px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.98) 0%, rgba(248, 250, 252, 0.95) 100%);
    backdrop-filter: blur(10px);
    border: 2px dashed #cbd5e1;
    border-radius: 24px;
    animation: fadeIn 0.5s ease-out;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.empty-state-icon {
    width: 104px;
    height: 104px;
    margin: 0 auto 28px;
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.12) 0%, rgba(234, 88, 12, 0.08) 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #f59e0b;
}

.empty-state h2 {
    margin: 0 0 12px;
    font-size: 1.4rem;
    font-weight: 700;
    color: #1e293b;
}

.empty-state p {
    margin: 0 0 28px;
    color: #64748b;
    font-size: 1rem;
    max-width: 360px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
}

/* ===== Responsive ===== */
@media (max-width: 768px) {
    .page-header {
        flex-direction: column;
        gap: 20px;
    }

    .page-header-icon {
        width: 56px;
        height: 56px;
    }

    .page-header-content h1 {
        font-size: 1.5rem;
    }

    .btn {
        width: 100%;
        justify-content: center;
    }

    .assistants-grid {
        grid-template-columns: 1fr;
    }

    .assistant-card {
        flex-wrap: wrap;
    }

    .assistant-actions {
        width: 100%;
        justify-content: flex-end;
        margin-top: 8px;
    }
}
</style>
{% endblock %}
